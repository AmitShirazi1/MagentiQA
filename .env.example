# MagentiQA — Environment Variables
# Copy this file to .env and fill in values (defaults are fine for local dev).

# Server
PORT=3000

# Session cookie signing secret — auto-generated if unset, but set a long random
# string for sessions that survive restarts.
SESSION_SECRET=change_me_to_a_long_random_string

# Electronic-signature HMAC key. DO NOT change this once signatures exist, or
# verification of previously-signed executions will fail.
SIGNATURE_SECRET=change_me_to_another_long_random_string

# CI webhook API key (for POST /api/executions/ci). Legacy VMS_CI_API_KEY is
# still honored.
MAGENTIQA_CI_API_KEY=change_me

# Google Drive / Docs integration (optional) — see README "Google Drive Sync".
# Create an OAuth client of type "Desktop app" at console.cloud.google.com.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Default Drive folders (URL or ID) the folder pickers open at (optional).
GOOGLE_IMPORT_FOLDER=
GOOGLE_EXPORT_FOLDER=
